# PostgreSQL / pgvector backend
DATABASE_URL=postgresql://vectorlog:vectorlog@localhost:5432/vectorlogdb

# OpenSearch backend
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin
OPENSEARCH_INDEX_PREFIX=vectorlog

# Embedding model
MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=128
EMBEDDING_DEVICE=cpu

# Search defaults
SEARCH_TOP_K=20

# Log ingestion
LOG_YEAR=2024
RAW_LOG_PATH=data/raw/OpenSSH/OpenSSH_full.log
STRUCTURED_CSV_PATH=data/raw/OpenSSH/OpenSSH_full.log_structured.csv
TEMPLATES_CSV_PATH=data/raw/OpenSSH/OpenSSH_full.log_templates.csv
PROCESSED_DIR=data/processed

# Anomaly detection
ANOMALY_CONTAMINATION=0.05
ANOMALY_N_ESTIMATORS=100

# Alerting
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_FROM_EMAIL=
ALERT_TO_EMAIL=
ALERT_SEVERITY_THRESHOLD=high
