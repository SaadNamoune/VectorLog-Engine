{
  "__inputs": [
    {
      "name": "DS_POSTGRESQL",
      "label": "PostgreSQL",
      "description": "VectorLog PostgreSQL datasource",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "title": "VectorLog-Engine — Security Analytics",
  "uid": "vectorlog-security",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "tags": ["vectorlog", "security", "logs"],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Log Entries",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 3 },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT COUNT(*) FROM log_entries",
          "format": "table"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Events (24h)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 3 },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT COUNT(*) FROM log_entries WHERE level = 'ERROR' AND log_timestamp > NOW() - INTERVAL '24 hours'",
          "format": "table"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Distinct Message Patterns",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 3 },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT COUNT(*) FROM message_embeddings",
          "format": "table"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Log Volume Over Time",
      "gridPos": { "x": 0, "y": 3, "w": 24, "h": 7 },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT date_trunc('hour', log_timestamp) AS time, level, COUNT(*) AS count FROM log_entries WHERE log_timestamp IS NOT NULL GROUP BY 1, 2 ORDER BY 1",
          "format": "table"
        }
      ]
    },
    {
      "id": 5,
      "type": "piechart",
      "title": "Log Level Distribution",
      "gridPos": { "x": 0, "y": 10, "w": 8, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT level, COUNT(*) AS count FROM log_entries GROUP BY level ORDER BY count DESC",
          "format": "table"
        }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Top 20 Most Frequent Error Patterns",
      "gridPos": { "x": 8, "y": 10, "w": 16, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT event_template, COUNT(*) AS occurrences FROM log_entries WHERE level = 'ERROR' GROUP BY event_template ORDER BY occurrences DESC LIMIT 20",
          "format": "table"
        }
      ]
    }
  ]
}
